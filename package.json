{
  "name": "@qualithm/arrow-flight-client",
  "version": "0.1.9",
  "description": "Unified Arrow Flight and Flight SQL client for JavaScript and TypeScript runtimes.",
  "private": false,
  "type": "module",
  "keywords": [
    "arrow",
    "flight",
    "flight-sql",
    "grpc",
    "apache-arrow",
    "typescript"
  ],
  "sideEffects": false,
  "license": "Apache-2.0",
  "author": "Qualithm",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qualithm/arrow-flight-client-js.git"
  },
  "homepage": "https://github.com/qualithm/arrow-flight-client-js#readme",
  "bugs": {
    "url": "https://github.com/qualithm/arrow-flight-client-js/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./dist/index.js",
      "deno": "./dist/index.js",
      "node": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./testing": {
      "bun": "./dist/testing/index.js",
      "deno": "./dist/testing/index.js",
      "node": "./dist/testing/index.js",
      "import": "./dist/testing/index.js",
      "types": "./dist/testing/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "analyze:bundle": "bun run scripts/analyze-bundle.ts",
    "bench:ipc": "bun run bench/ipc.ts",
    "bench": "bun run bench/index.ts",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "build": "tsc -p tsconfig.build.json && cp -r src/gen dist/gen",
    "clean": "rm -rf dist",
    "dev": "bun --watch run src/index.ts",
    "docs": "typedoc",
    "format:fix": "prettier --write .",
    "format": "prettier --check .",
    "generate:proto": "buf generate",
    "lint:fix": "eslint --fix .",
    "lint": "eslint .",
    "prepublishOnly": "bun run clean && bun run build",
    "start": "bun run src/index.ts",
    "test:coverage:unit": "vitest run --coverage src/__tests__/unit",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run src/__tests__/integration",
    "test:unit": "vitest run src/__tests__/unit",
    "test:watch": "vitest",
    "test": "vitest run src/__tests__/unit",
    "typecheck": "tsc -p tsconfig.node.json --noEmit",
    "validate:runtime": "bun run scripts/validate-runtime.ts"
  },
  "dependencies": {
    "@bufbuild/protobuf": "2.12.0",
    "@connectrpc/connect": "2.1.1",
    "@connectrpc/connect-node": "2.1.1",
    "apache-arrow": "21.1.0"
  },
  "devDependencies": {
    "@bufbuild/buf": "1.68.4",
    "@bufbuild/protoc-gen-es": "2.12.0",
    "@eslint/js": "10.0.1",
    "@types/bun": "1.3.13",
    "@vitest/coverage-istanbul": "4.1.5",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "10.2.1",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-plugin-unused-imports": "4.4.1",
    "globals": "17.5.0",
    "jiti": "2.6.1",
    "prettier": "3.8.3",
    "typedoc": "0.28.19",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.0",
    "vitest": "4.1.5"
  },
  "overrides": {
    "brace-expansion": "5.0.5",
    "picomatch": "4.0.4",
    "postcss": "8.5.10",
    "yaml": "2.8.3"
  }
}
