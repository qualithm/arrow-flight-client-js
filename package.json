{
  "name": "@qualithm/arrow-flight-client",
  "version": "0.1.0",
  "description": "Unified Arrow Flight client for JavaScript and TypeScript runtimes.",
  "private": false,
  "type": "module",
  "keywords": [
    "arrow",
    "flight",
    "flight-sql",
    "grpc",
    "apache-arrow",
    "typescript"
  ],
  "license": "Apache-2.0",
  "author": "Qualithm",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qualithm/arrow-flight-client-js.git"
  },
  "homepage": "https://github.com/qualithm/arrow-flight-client-js#readme",
  "bugs": {
    "url": "https://github.com/qualithm/arrow-flight-client-js/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./dist/index.js",
      "node": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "analyze:bundle": "bun run scripts/analyze-bundle.ts",
    "bench:ipc": "bun run bench/ipc.ts",
    "bench": "bun run bench/index.ts",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "dev": "bun --watch run src/index.ts",
    "docs": "typedoc",
    "format:fix": "prettier --write .",
    "format": "prettier --check .",
    "generate:proto": "buf generate",
    "lint:fix": "eslint --fix .",
    "lint": "eslint .",
    "prepublishOnly": "bun run clean && bun run build",
    "start": "bun run src/index.ts",
    "test:coverage:unit": "vitest run --coverage src/__tests__/unit",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run src/__tests__/integration",
    "test:unit": "vitest run src/__tests__/unit",
    "test:watch": "vitest",
    "test": "vitest run src/__tests__/unit",
    "typecheck": "tsc -p tsconfig.node.json --noEmit",
    "validate:runtime": "bun run scripts/validate-runtime.ts"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-node": "^2.1.1",
    "apache-arrow": "^21.1.0"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.66.0",
    "@bufbuild/protoc-gen-es": "^2.11.0",
    "@eslint/js": "10.0.1",
    "@types/bun": "1.3.10",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "10.0.2",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-unused-imports": "4.4.1",
    "globals": "17.4.0",
    "jiti": "2.6.1",
    "prettier": "3.8.1",
    "typedoc": "0.28.17",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "minimatch": "10.2.3",
    "undici": "6.23.0"
  }
}
